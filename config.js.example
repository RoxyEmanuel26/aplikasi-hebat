  PEAK_MULTIPLIER: 2,

  // ========== EXIT BEHAVIOR CONFIG ==========
  EXIT_SCROLL_BOTTOM_CHANCE: 0.40,
  EXIT_CLICK_BACK_CHANCE: 0.20,
  EXIT_BOUNCE_CHANCE: 0.15,

  // ========== DEVICE PROFILE CONFIG ==========
  USE_CONSISTENT_DEVICE_PROFILE: true,
  DEVICE_PROFILE_DIR: './device-profiles',

  // ========== MULTI WEBSITE CONFIG ==========
  // Aktifkan mode multi website queue
  // true  = jalankan semua website di WEBSITE_QUEUE secara berurutan
