  // ========== POPUNDER CONFIG ==========
  POPUNDER_ENABLED: true,
  POPUNDER_MIN_DELAY: 2000,
  POPUNDER_MAX_DELAY: 5000,
  POPUNDER_MAX_TABS: 3,

  // ========== MODE CONFIG ==========
  // Gunakan proxy Evomi Residential Core?
  USE_PROXY: true,
  TEST_MODE: false,

  // ========== PROXY EFFICIENCY CONFIG ==========
  // Maksimal jumlah visit per IP proxy per hari (1 = IP baru setiap visit, optimal untuk popunder)
